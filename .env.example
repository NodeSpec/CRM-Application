# =============================================================================
# CRM Platform — Environment Configuration (REQ-015)
# =============================================================================
# Copy this file to `.env` and fill in real values before `docker compose up`.
# `.env` is git-ignored and must NEVER be committed. Only this example is tracked.
# The CRM API validates these at startup and FAILS FAST with a descriptive error
# if a required variable is missing (see services/api/src/config.ts).
# =============================================================================

# --- Runtime --------------------------------------------------------------
# Node environment: "development" | "production" | "test"
NODE_ENV=development
# Port the CRM API listens on inside its container (not published to the host).
PORT=3000

# --- PostgreSQL (CRM Database) -------------------------------------------
# Credentials used by the `db` service to initialise the database.
POSTGRES_USER=crm
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=crm
# Connection string the API uses. Host `db` is the compose service name.
# For TLS to a managed provider use sslmode=require.
DATABASE_URL=postgresql://crm:change-me-postgres@db:5432/crm

# --- Redis (Session Store) -----------------------------------------------
# Password enforced via `requirepass` on the redis service.
REDIS_PASSWORD=change-me-redis
# Connection URL the API uses. Host `session-store` is the compose service name.
# Use rediss:// for TLS connections.
REDIS_URL=redis://:change-me-redis@session-store:6379

# --- Session & Cookies (REQ-003) -----------------------------------------
# Secret used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-session-secret-at-least-32-chars
# Idle timeout in minutes before a session expires (default 30).
SESSION_IDLE_TIMEOUT_MIN=30
# Set to "true" in production so cookies are only sent over HTTPS.
COOKIE_SECURE=false

# --- App base URL (browser-facing, through the proxy) --------------------
# Used to build OIDC redirect URIs and the post-login redirect.
APP_BASE_URL=http://localhost

# --- Identity Provider / OIDC (REQ-001) ----------------------------------
# Browser-facing issuer/authorize base — the URL the USER'S BROWSER reaches the
# IdP at (through the reverse proxy). For the bundled Keycloak:
OIDC_ISSUER_URL=http://localhost/auth/realms/crm
# Server-to-server base — the URL the API CONTAINER reaches the IdP at for token
# exchange + JWKS. For the bundled Keycloak on the internal network:
OIDC_INTERNAL_URL=http://idp:8080/auth/realms/crm
# Confidential client used by the API for the backend-for-frontend login flow.
# Must match the crm-api client in infra/keycloak/realm-export.json.
OIDC_CLIENT_ID=crm-api
OIDC_CLIENT_SECRET=crm-api-dev-secret
# Optional SAML 2.0 alternative: metadata URL or path to mounted XML.
SAML_METADATA_URL=
# Token claim (or group claim) the API maps to CRM roles (REQ-002).
IDP_ROLE_CLAIM=groups

# --- Keycloak admin bootstrap (Identity Provider container) ---------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin

# --- Alert thresholds / feature flags (REQ-008, REQ-010, REQ-015) ---------
# B2G opportunities within this many days of their Due Date are flagged (default 14).
B2G_DUE_DATE_THRESHOLD_DAYS=14
# Submissions within this many days of their Deadline are flagged (default 14).
SUBMISSION_DEADLINE_THRESHOLD_DAYS=14
# Feature flags (comma-separated) — reserved for future toggles.
FEATURE_FLAGS=

# --- Social profile integrations (REQ-026) --------------------------------
# Company 360 stores each company's official social profile URLs. Rendering a
# LIVE post feed from LinkedIn/X/Instagram/TikTok requires each platform's
# official API and MUST route through a dedicated egress gateway (allowlist +
# rate limiting + credential injection) — never direct calls from app code.
# Leave these blank and the feed reports "not connected" and returns no posts
# (it never fabricates data).
# Base URL of the egress gateway that fronts the third-party social APIs.
SOCIAL_EGRESS_BASE_URL=
# Per-platform API credentials (injected by the gateway in production).
SOCIAL_LINKEDIN_TOKEN=
SOCIAL_X_TOKEN=
SOCIAL_INSTAGRAM_TOKEN=
SOCIAL_TIKTOK_TOKEN=

# --- Email / calendar invite delivery (REQ-027) ---------------------------
# Event invites work client-side out of the box (Outlook/Google deeplinks +
# downloadable .ics) with NO config. These vars are only needed for SERVER-side
# delivery — emailing attendees directly from the API. Sending routes through an
# email gateway (managed SMTP relay or Microsoft Graph) reached via the egress
# gateway; the API holds no mail credentials directly. Leave EMAIL_GATEWAY_URL
# blank and POST /events/:id/invite returns the .ics with delivered=false.
EMAIL_GATEWAY_URL=
EMAIL_FROM=
EMAIL_API_TOKEN=

# --- Web app build-time config -------------------------------------------
# Public base path the SPA calls for the API (served through the reverse proxy).
# Login is backend-driven (BFF), so the SPA needs no OIDC client config.
VITE_API_BASE_URL=/api/v1
