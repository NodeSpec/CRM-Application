{
  "realm": "crm",
  "enabled": true,
  "displayName": "CRM Platform",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      { "name": "admin", "description": "Full read/write/delete + user management (REQ-002)" },
      { "name": "member", "description": "Read/write within assigned modules, no user management (REQ-002)" }
    ]
  },
  "groups": [
    { "name": "Admins", "path": "/Admins", "realmRoles": ["admin"] },
    { "name": "Members", "path": "/Members", "realmRoles": ["member"] }
  ],
  "defaultGroups": ["/Members"],
  "clients": [
    {
      "clientId": "crm-web",
      "name": "CRM Web App (SPA)",
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost/*", "https://localhost/*"],
      "webOrigins": ["http://localhost", "https://localhost", "+"],
      "attributes": { "pkce.code.challenge.method": "S256" }
    },
    {
      "clientId": "crm-api",
      "name": "CRM API (backend / BFF)",
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "crm-api-dev-secret",
      "redirectUris": [
        "http://localhost/api/v1/auth/callback",
        "https://localhost/api/v1/auth/callback"
      ],
      "webOrigins": ["http://localhost", "https://localhost"],
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "admin", "temporary": false }
      ],
      "groups": ["/Admins"]
    },
    {
      "username": "member",
      "email": "member@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Member",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "member", "temporary": false }
      ],
      "groups": ["/Members"]
    }
  ]
}
